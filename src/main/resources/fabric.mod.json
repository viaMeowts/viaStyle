{
  "schemaVersion": 1,
  "id": "viastyle",
  "version": "${version}",
  "name": "viaStyle",
  "description": "Chat system with local/global/staff channels, tab list styling, nick coloring & more.",
  "authors": [
    "viaMeowts"
  ],
  "contact": {
    "homepage": "https://github.com/viaMeowts/viaStyle",
    "sources": "https://github.com/viaMeowts/viaStyle"
  },
  "license": "MIT",
  "icon": "assets/viastyle/icon.png",
  "environment": "server",
  "entrypoints": {
    "main": [
      "com.viameowts.viastyle.viaStyle"
    ],
    "server": [
      "com.viameowts.viastyle.viaStyleServer"
    ]
  },
  "mixins": [
    "viastyle.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "~${minecraft_version}",
    "java": ">=21"
  },
  "suggests": {
    "placeholder-api": "*",
    "banhammer": "*",
    "luckperms": "*",
    "blockbot": "*",
    "blockbot-api": "*",
    "carpet": "*"
  }
}